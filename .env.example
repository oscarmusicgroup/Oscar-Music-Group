# Base URL
NUXT_PUBLIC_BASE_URL=https://oscarmusicgroup.vn

# API Configuration
NUXT_PUBLIC_API_BASE=https://api.oscarmusicgroup.vn/v1

# Google analytics
NUXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Google Site Verification
NUXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_verification_code

# Email Configuration (for contact form)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
ADMIN_EMAIL=admin@oscarmusicgroup.vn

# Database (optional)
DATABASE_URL=postgresql://user:password@localhost:5432/oscar_music_group

# Redis (optional - for caching)
REDIS_URL=redis://localhost:6379

# AWS S3 (optional - for file storage)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_BUCKET=oscar-music-group-files
