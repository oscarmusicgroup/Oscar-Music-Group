{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./",
    "removeComments": true,
    "noEmit": true,
    "importHelpers": true,
    "isolatedModules": true,
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "#app": [".nuxt"],
      "#build": [".nuxt"],
      "#head": [".nuxt/head"],
      "#imports": [".nuxt/imports"],
      "#app-config": [".nuxt/app.config"],
      "#internal": [".nuxt/dist/app"],
      "~": ["./app"],
      "@": ["./app"],
      "~~": ["."],
      "@@": ["."]
    },
    "types": ["nitropack/types", "node"]
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "app/**/*.vue",
    "nuxt.config.ts",
    ".nuxt/nuxt.d.ts",
    "server/**/*.ts"
  ]
}
